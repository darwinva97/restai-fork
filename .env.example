# ── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_USER=restai
POSTGRES_PASSWORD=change-me-in-production

# ── API Server ────────────────────────────────────────────────────────
API_PORT=3001
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000

# ── Database (composed automatically in docker-compose) ───────────────
# Only needed when running outside Docker:
# DATABASE_URL=postgresql://restai:change-me-in-production@localhost:5432/restai
# Driver de DB (portabilidad sin tocar código):
#   postgres-js (default) = TCP clásico (contenedor / Postgres local)
#   neon                  = driver serverless de Neon (HTTP/WebSocket)
# Si no se define, se autodetecta: una URL *.neon.tech usa "neon".
# DATABASE_DRIVER=postgres-js

# ── Redis (hardcoded in docker-compose as redis://redis:6379) ─────────
# Only needed when running outside Docker:
# REDIS_URL=redis://localhost:6379

# ── Cloudflare R2 Storage ────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=restai
R2_PUBLIC_URL=

# ── Realtime (mensajería en vivo) ────────────────────────────────────
# Proveedor: websocket (default, WS de Bun + Redis) | pusher | ably | noop
REALTIME_PROVIDER=websocket
# Pusher (si REALTIME_PROVIDER=pusher):
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
# Ably (si REALTIME_PROVIDER=ably): API key con formato appId.keyId:keySecret
ABLY_API_KEY=

# ── SUNAT (Facturación Electrónica) ──────────────────────────────────
# Clave para cifrar en reposo las credenciales SOL y el certificado digital.
# Usa una cadena aleatoria de 32+ caracteres. Generar: openssl rand -hex 32
SUNAT_ENCRYPTION_KEY=change-me-32-chars-random-string
# El emisor (RUC, certificado, credenciales SOL, ambiente beta/production) se
# configura por organización vía PUT /api/sunat/config y se guarda cifrado en BD.

# ── Web App (build-time — set as Build Variable in Coolify) ──────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ── Port mapping (optional) ──────────────────────────────────────────
WEB_PORT=3000
